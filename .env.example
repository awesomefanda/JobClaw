# ─── JobClaw Configuration ───
# Copy to .env and fill in your keys.

# Required: Groq API key (free at https://console.groq.com)
GROQ_API_KEY=

# Optional: Apollo.io API key (free tier 50 credits/month)
# People Search is FREE (no credits). Enrichment costs credits.
# https://app.apollo.io → Settings → API Keys
APOLLO_API_KEY=

# Scoring threshold (0.0 - 1.0). Default 0.75
MIN_FIT_SCORE=0.75

# Groq model to use
GROQ_MODEL=llama-3.3-70b-versatile

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
